  val () = $B.bput(b,"          },\n")
  val () = $B.bput(b,"          () => { instance.exports.bats_on_clipboard_read_complete(resolverId, 0); }\n")
  val () = $B.bput(b,"        );\n")
  val () = $B.bput(b,"      } else {\n")
  val () = $B.bput(b,"        instance.exports.bats_on_clipboard_read_complete(resolverId, 0);\n")
  val () = $B.bput(b,"      }\n")
  val () = $B.bput(b,"    } catch(e) {\n")
  val () = $B.bput(b,"      instance.exports.bats_on_clipboard_read_complete(resolverId, 0);\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"  }\n")
in end

fn emit_js_file {n:nat | n + 1700 <= $B.BUILDER_CAP}
  (b: !$B.builder(n) >> [m:nat | n <= m; m <= n + 1700] $B.builder(m)): void = let
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  // --- File ---\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  const fileCache = new Map();\n")
  val () = $B.bput(b,"  let nextFileHandle = 1;\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsFileOpen(idPtr, idLen, resolverId) {\n")
  val () = $B.bput(b,"    const id = readIdFromPtr(idPtr, idLen);\n")
  val () = $B.bput(b,"    const el = getEl(id);\n")
  val () = $B.bput(b,"    if (!el || !el.files || !el.files[0]) {\n")
  val () = $B.bput(b,"      instance.exports.bats_bridge_stash_set_int(2, 0);\n")
  val () = $B.bput(b,"      instance.exports.bats_on_file_open(resolverId, 0, 0);\n")
  val () = $B.bput(b,"      return;\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"    const file = el.files[0];\n")
  val () = $B.bput(b,"    const reader = new FileReader();\n")
  val () = $B.bput(b,"    reader.onload = () => {\n")
  val () = $B.bput(b,"      const handle = nextFileHandle++;\n")
  val () = $B.bput(b,"      const data = new Uint8Array(reader.result);\n")
  val () = $B.bput(b,"      fileCache.set(handle, data);\n")
  val () = $B.bput(b,"      const nameBytes = new TextEncoder().encode(file.name);\n")
  val () = $B.bput(b,"      const nameStashId = stashData(nameBytes);\n")
  val () = $B.bput(b,"      instance.exports.bats_bridge_stash_set_int(1, nameStashId);\n")
  val () = $B.bput(b,"      instance.exports.bats_bridge_stash_set_int(2, nameBytes.length);\n")
  val () = $B.bput(b,"      instance.exports.bats_on_file_open(resolverId, handle, data.length);\n")
  val () = $B.bput(b,"    };\n")
  val () = $B.bput(b,"    reader.onerror = () => {\n")
  val () = $B.bput(b,"      instance.exports.bats_bridge_stash_set_int(2, 0);\n")
  val () = $B.bput(b,"      instance.exports.bats_on_file_open(resolverId, 0, 0);\n")
  val () = $B.bput(b,"    };\n")
  val () = $B.bput(b,"    reader.readAsArrayBuffer(file);\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsFileRead(handle, fileOffset, len, outPtr) {\n")
  val () = $B.bput(b,"    const data = fileCache.get(handle);\n")
  val () = $B.bput(b,"    if (!data) return 0;\n")
  val () = $B.bput(b,"    const available = Math.max(0, data.length - fileOffset);\n")
  val () = $B.bput(b,"    const copyLen = Math.min(len, available);\n")
  val () = $B.bput(b,"    if (copyLen > 0) {\n")
  val () = $B.bput(b,"      new Uint8Array(instance.exports.memory.buffer).set(\n")
  val () = $B.bput(b,"        data.subarray(fileOffset, fileOffset + copyLen), outPtr);\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"    return copyLen;\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsFileClose(handle) {\n")
  val () = $B.bput(b,"    fileCache.delete(handle);\n")
  val () = $B.bput(b,"  }\n")
in end

fn emit_js_decompress {n:nat | n + 2000 <= $B.BUILDER_CAP}
  (b: !$B.builder(n) >> [m:nat | n <= m; m <= n + 2000] $B.builder(m)): void = let
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  // --- Decompress ---\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  const blobCache = new Map();\n")
  val () = $B.bput(b,"  let nextBlobHandle = 1;\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsDecompress(dataPtr, dataLen, method, resolverId) {\n")
  val () = $B.bput(b,"    const compressed = readBytes(dataPtr, dataLen);\n")
  val () = $B.bput(b,"    const formats = ['gzip', 'deflate', 'deflate-raw'];\n")
  val () = $B.bput(b,"    const format = formats[method];\n")
  val () = $B.bput(b,"    if (!format || typeof DecompressionStream === 'undefined') {\n")
  val () = $B.bput(b,"      instance.exports.bats_on_decompress_complete(resolverId, 0, 0);\n")
  val () = $B.bput(b,"      return;\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"    const ds = new DecompressionStream(format);\n")
  val () = $B.bput(b,"    const writer = ds.writable.getWriter();\n")
  val () = $B.bput(b,"    writer.write(compressed);\n")
  val () = $B.bput(b,"    writer.close();\n")
  val () = $B.bput(b,"    const reader = ds.readable.getReader();\n")
  val () = $B.bput(b,"    const chunks = [];\n")
  val () = $B.bput(b,"    (function pump() {\n")
  val () = $B.bput(b,"      reader.read().then(({ done, value }) => {\n")
  val () = $B.bput(b,"        if (value) chunks.push(value);\n")
  val () = $B.bput(b,"        if (done) {\n")
  val () = $B.bput(b,"          let totalLen = 0;\n")
  val () = $B.bput(b,"          for (const c of chunks) totalLen += c.length;\n")
  val () = $B.bput(b,"          const result = new Uint8Array(totalLen);\n")
  val () = $B.bput(b,"          let off = 0;\n")
  val () = $B.bput(b,"          for (const c of chunks) { result.set(c, off); off += c.length; }\n")
  val () = $B.bput(b,"          const handle = nextBlobHandle++;\n")
  val () = $B.bput(b,"          blobCache.set(handle, result);\n")
  val () = $B.bput(b,"          instance.exports.bats_on_decompress_complete(resolverId, handle, result.length);\n")
  val () = $B.bput(b,"        } else {\n")
  val () = $B.bput(b,"          pump();\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"      }).catch(() => {\n")
  val () = $B.bput(b,"        instance.exports.bats_on_decompress_complete(resolverId, 0, 0);\n")
  val () = $B.bput(b,"      });\n")
  val () = $B.bput(b,"    })();\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsBlobRead(handle, blobOffset, len, outPtr) {\n")
