in end

fn emit_js_idb {n:nat | n + 3500 <= $B.BUILDER_CAP}
  (b: !$B.builder(n) >> [m:nat | n <= m; m <= n + 3500] $B.builder(m)): void = let
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  // --- IndexedDB ---\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  let dbPromise = null;\n")
  val () = $B.bput(b,"  function openDB() {\n")
  val () = $B.bput(b,"    if (!dbPromise) {\n")
  val () = $B.bput(b,"      dbPromise = new Promise((resolve, reject) => {\n")
  val () = $B.bput(b,"        const req = indexedDB.open('bats', 1);\n")
  val () = $B.bput(b,"        req.onupgradeneeded = () => {\n")
  val () = $B.bput(b,"          req.result.createObjectStore('kv');\n")
  val () = $B.bput(b,"        };\n")
  val () = $B.bput(b,"        req.onsuccess = () => resolve(req.result);\n")
  val () = $B.bput(b,"        req.onerror = () => reject(req.error);\n")
  val () = $B.bput(b,"      });\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"    return dbPromise;\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsIdbPut(keyPtr, keyLen, valPtr, valLen, resolverId) {\n")
  val () = $B.bput(b,"    const key = readString(keyPtr, keyLen);\n")
  val () = $B.bput(b,"    const val_ = readBytes(valPtr, valLen);\n")
  val () = $B.bput(b,"    openDB().then(db => {\n")
  val () = $B.bput(b,"      const tx = db.transaction('kv', 'readwrite');\n")
  val () = $B.bput(b,"      tx.objectStore('kv').put(val_, key);\n")
  val () = $B.bput(b,"      tx.oncomplete = () => {\n")
  val () = $B.bput(b,"        instance.exports.bats_idb_fire(resolverId, 0);\n")
  val () = $B.bput(b,"      };\n")
  val () = $B.bput(b,"      tx.onerror = () => {\n")
  val () = $B.bput(b,"        instance.exports.bats_idb_fire(resolverId, -1);\n")
  val () = $B.bput(b,"      };\n")
  val () = $B.bput(b,"    });\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsIdbGet(keyPtr, keyLen, resolverId) {\n")
  val () = $B.bput(b,"    const key = readString(keyPtr, keyLen);\n")
  val () = $B.bput(b,"    openDB().then(db => {\n")
  val () = $B.bput(b,"      const tx = db.transaction('kv', 'readonly');\n")
  val () = $B.bput(b,"      const req = tx.objectStore('kv').get(key);\n")
  val () = $B.bput(b,"      req.onsuccess = () => {\n")
  val () = $B.bput(b,"        const result = req.result;\n")
  val () = $B.bput(b,"        if (result === undefined) {\n")
  val () = $B.bput(b,"          instance.exports.bats_idb_fire_get(resolverId, 0);\n")
  val () = $B.bput(b,"        } else {\n")
  val () = $B.bput(b,"          const data = new Uint8Array(result);\n")
  val () = $B.bput(b,"          const stashId = stashData(data);\n")
  val () = $B.bput(b,"          instance.exports.bats_bridge_stash_set_int(1, stashId);\n")
  val () = $B.bput(b,"          instance.exports.bats_idb_fire_get(resolverId, data.length);\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"      };\n")
  val () = $B.bput(b,"      req.onerror = () => {\n")
  val () = $B.bput(b,"        instance.exports.bats_idb_fire_get(resolverId, 0);\n")
  val () = $B.bput(b,"      };\n")
  val () = $B.bput(b,"    });\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsIdbDelete(keyPtr, keyLen, resolverId) {\n")
  val () = $B.bput(b,"    const key = readString(keyPtr, keyLen);\n")
  val () = $B.bput(b,"    openDB().then(db => {\n")
  val () = $B.bput(b,"      const tx = db.transaction('kv', 'readwrite');\n")
  val () = $B.bput(b,"      tx.objectStore('kv').delete(key);\n")
  val () = $B.bput(b,"      tx.oncomplete = () => {\n")
  val () = $B.bput(b,"        instance.exports.bats_idb_fire(resolverId, 0);\n")
  val () = $B.bput(b,"      };\n")
  val () = $B.bput(b,"      tx.onerror = () => {\n")
  val () = $B.bput(b,"        instance.exports.bats_idb_fire(resolverId, -1);\n")
  val () = $B.bput(b,"      };\n")
  val () = $B.bput(b,"    });\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  (* IDB list keys *)
  val () = $B.bput(b,"  function batsIdbListKeys(prefixPtr, prefixLen, resolverId) {\n")
  val () = $B.bput(b,"    const prefix = readString(prefixPtr, prefixLen);\n")
  val () = $B.bput(b,"    openDB().then(db => {\n")
  val () = $B.bput(b,"      const tx = db.transaction('kv', 'readonly');\n")
  val () = $B.bput(b,"      const req = tx.objectStore('kv').getAllKeys();\n")
  val () = $B.bput(b,"      req.onsuccess = () => {\n")
  val () = $B.bput(b,"        const keys = req.result.filter(k => typeof k === 'string' && k.startsWith(prefix));\n")
  val () = $B.bput(b,"        const chunks = [];\n")
  val () = $B.bput(b,"        let totalLen = 0;\n")
  val () = $B.bput(b,"        for (const k of keys) {\n")
  val () = $B.bput(b,"          const kb = new TextEncoder().encode(k);\n")
  val () = $B.bput(b,"          const hdr = new Uint8Array(2);\n")
  val () = $B.bput(b,"          hdr[0] = kb.length & 0xFF; hdr[1] = (kb.length >> 8) & 0xFF;\n")
  val () = $B.bput(b,"          chunks.push(hdr); chunks.push(kb);\n")
  val () = $B.bput(b,"          totalLen += 2 + kb.length;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        if (totalLen === 0) { instance.exports.bats_idb_fire_get(resolverId, 0); return; }\n")
  val () = $B.bput(b,"        const combined = new Uint8Array(totalLen);\n")
  val () = $B.bput(b,"        let off = 0;\n")
  val () = $B.bput(b,"        for (const c of chunks) { combined.set(c, off); off += c.length; }\n")
  val () = $B.bput(b,"        const stashId = stashData(combined);\n")
  val () = $B.bput(b,"        instance.exports.bats_bridge_stash_set_int(1, stashId);\n")
  val () = $B.bput(b,"        instance.exports.bats_idb_fire_get(resolverId, totalLen);\n")
  val () = $B.bput(b,"      };\n")
  val () = $B.bput(b,"      req.onerror = () => { instance.exports.bats_idb_fire_get(resolverId, 0); };\n")
  val () = $B.bput(b,"    });\n")
  val () = $B.bput(b,"  }\n")
in end

fn emit_js_window {n:nat | n + 600 <= $B.BUILDER_CAP}
  (b: !$B.builder(n) >> [m:nat | n <= m; m <= n + 600] $B.builder(m)): void = let
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  // --- Window ---\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsFocusWindow() {\n")
  val () = $B.bput(b,"    try { root.ownerDocument.defaultView.focus(); } catch(e) {}\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsGetVisibilityState() {\n")
  val () = $B.bput(b,"    try {\n")
  val () = $B.bput(b,"      return document.visibilityState === 'hidden' ? 1 : 0;\n")
  val () = $B.bput(b,"    } catch(e) { return 0; }\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsLog(level, msgPtr, msgLen) {\n")
  val () = $B.bput(b,"    const msg = readString(msgPtr, msgLen);\n")
  val () = $B.bput(b,"    const labels = ['debug', 'info', 'warn', 'error'];\n")
  val () = $B.bput(b,"    const label = labels[level] || 'log';\n")
  val () = $B.bput(b,"    console.log(`[bats:${label}] ${msg}`);\n")
  val () = $B.bput(b,"  }\n")
in end

