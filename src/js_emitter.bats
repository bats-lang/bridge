fn emit_js_xml {n:nat | n + 3000 <= $B.BUILDER_CAP}
  (b: !$B.builder(n) >> [m:nat | n <= m; m <= n + 3000] $B.builder(m)): void = let
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  // --- HTML parsing ---\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  const FILTERED_TAGS = new Set([\n")
  val () = $B.bput(b,"    'script', 'iframe', 'object', 'embed', 'form', 'input', 'link', 'meta'\n")
  val () = $B.bput(b,"  ]);\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsParseHtml(htmlPtr, htmlLen) {\n")
  val () = $B.bput(b,"    const html = readString(htmlPtr, htmlLen);\n")
  val () = $B.bput(b,"    let doc;\n")
  val () = $B.bput(b,"    try {\n")
  val () = $B.bput(b,"      const win = root.ownerDocument.defaultView;\n")
  val () = $B.bput(b,"      if (typeof win.DOMParser !== 'undefined') {\n")
  val () = $B.bput(b,"        doc = new win.DOMParser().parseFromString(html, 'text/html');\n")
  val () = $B.bput(b,"      } else {\n")
  val () = $B.bput(b,"        return 0;\n")
  val () = $B.bput(b,"      }\n")
  val () = $B.bput(b,"    } catch(e) { return 0; }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"    const chunks = [];\n")
  val () = $B.bput(b,"    let totalLen = 0;\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"    function pushByte(b) { chunks.push(new Uint8Array([b])); totalLen += 1; }\n")
  val () = $B.bput(b,"    function pushU16LE(v) { chunks.push(new Uint8Array([v & 0xFF, (v >> 8) & 0xFF])); totalLen += 2; }\n")
  val () = $B.bput(b,"    function pushBytes(arr) { chunks.push(arr); totalLen += arr.length; }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"    function serializeNode(node) {\n")
  val () = $B.bput(b,"      if (node.nodeType === 1) {\n")
  val () = $B.bput(b,"        const tag = node.tagName.toLowerCase();\n")
  val () = $B.bput(b,"        if (FILTERED_TAGS.has(tag)) return;\n")
  val () = $B.bput(b,"        const tagBytes = new TextEncoder().encode(tag);\n")
  val () = $B.bput(b,"        if (tagBytes.length > 255) return;\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"        const attrs = [];\n")
  val () = $B.bput(b,"        for (let i = 0; i < node.attributes.length; i++) {\n")
  val () = $B.bput(b,"          const attr = node.attributes[i];\n")
  val () = $B.bput(b,"          if (/^on/i.test(attr.name)) continue;\n")
  val () = $B.bput(b,"          if (attr.name === 'style') continue;\n")
  val () = $B.bput(b,"          if (!/^[a-zA-Z0-9-]+$/.test(attr.name)) continue;\n")
  val () = $B.bput(b,"          const nameBytes = new TextEncoder().encode(attr.name);\n")
  val () = $B.bput(b,"          const valBytes = new TextEncoder().encode(attr.value);\n")
  val () = $B.bput(b,"          if (nameBytes.length > 255 || valBytes.length > 65535) continue;\n")
  val () = $B.bput(b,"          attrs.push({ nameBytes, valBytes });\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"        pushByte(0x01);\n")
  val () = $B.bput(b,"        pushByte(tagBytes.length);\n")
  val () = $B.bput(b,"        pushBytes(tagBytes);\n")
  val () = $B.bput(b,"        pushByte(attrs.length);\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"        for (const a of attrs) {\n")
  val () = $B.bput(b,"          pushByte(a.nameBytes.length);\n")
  val () = $B.bput(b,"          pushBytes(a.nameBytes);\n")
  val () = $B.bput(b,"          pushU16LE(a.valBytes.length);\n")
  val () = $B.bput(b,"          pushBytes(a.valBytes);\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"        for (let i = 0; i < node.childNodes.length; i++) {\n")
  val () = $B.bput(b,"          serializeNode(node.childNodes[i]);\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"        pushByte(0x02);\n")
  val () = $B.bput(b,"      } else if (node.nodeType === 3) {\n")
  val () = $B.bput(b,"        const text = node.textContent || '';\n")
  val () = $B.bput(b,"        if (text.length === 0) return;\n")
  val () = $B.bput(b,"        const textBytes = new TextEncoder().encode(text);\n")
  val () = $B.bput(b,"        if (textBytes.length > 65535) return;\n")
  val () = $B.bput(b,"        pushByte(0x03);\n")
  val () = $B.bput(b,"        pushU16LE(textBytes.length);\n")
  val () = $B.bput(b,"        pushBytes(textBytes);\n")
  val () = $B.bput(b,"      }\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"    const body = doc.body;\n")
  val () = $B.bput(b,"    if (body) {\n")
  val () = $B.bput(b,"      for (let i = 0; i < body.childNodes.length; i++) {\n")
  val () = $B.bput(b,"        serializeNode(body.childNodes[i]);\n")
  val () = $B.bput(b,"      }\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"    if (totalLen === 0) return 0;\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"    const combined = new Uint8Array(totalLen);\n")
  val () = $B.bput(b,"    let off = 0;\n")
  val () = $B.bput(b,"    for (const chunk of chunks) {\n")
  val () = $B.bput(b,"      combined.set(chunk, off);\n")
  val () = $B.bput(b,"      off += chunk.length;\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"    const stashId = stashData(combined);\n")
  val () = $B.bput(b,"    instance.exports.bats_bridge_stash_set_int(1, stashId);\n")
  val () = $B.bput(b,"    return totalLen;\n")
  val () = $B.bput(b,"  }\n")
in end

fn emit_js_blob {n:nat | n + 1200 <= $B.BUILDER_CAP}
  (b: !$B.builder(n) >> [m:nat | n <= m; m <= n + 1200] $B.builder(m)): void = let
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  // --- Blob URLs ---\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsCreateBlobUrl(dataPtr, dataLen, mimePtr, mimeLen) {\n")
  val () = $B.bput(b,"    const bytes = readBytes(dataPtr, dataLen);\n")
  val () = $B.bput(b,"    const mime = readString(mimePtr, mimeLen);\n")
  val () = $B.bput(b,"    const blob = new Blob([bytes], { type: mime });\n")
  val () = $B.bput(b,"    const url = URL.createObjectURL(blob);\n")
  val () = $B.bput(b,"    const urlBytes = new TextEncoder().encode(url);\n")
  val () = $B.bput(b,"    const stashId = stashData(urlBytes);\n")
  val () = $B.bput(b,"    instance.exports.bats_bridge_stash_set_int(1, stashId);\n")
  val () = $B.bput(b,"    return urlBytes.length;\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsRevokeBlobUrl(urlPtr, urlLen) {\n")
  val () = $B.bput(b,"    const url = readString(urlPtr, urlLen);\n")
  val () = $B.bput(b,"    try { URL.revokeObjectURL(url); } catch(e) {}\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsDownloadBlob(dataPtr, dataLen, mimePtr, mimeLen, namePtr, nameLen) {\n")
  val () = $B.bput(b,"    const bytes = readBytes(dataPtr, dataLen);\n")
  val () = $B.bput(b,"    const mime = readString(mimePtr, mimeLen);\n")
  val () = $B.bput(b,"    const name = readString(namePtr, nameLen);\n")
  val () = $B.bput(b,"    const blob = new Blob([bytes], { type: mime });\n")
  val () = $B.bput(b,"    const url = URL.createObjectURL(blob);\n")
  val () = $B.bput(b,"    const a = document.createElement('a');\n")
  val () = $B.bput(b,"    a.href = url; a.download = name;\n")
  val () = $B.bput(b,"    document.body.appendChild(a); a.click();\n")
  val () = $B.bput(b,"    document.body.removeChild(a);\n")
  val () = $B.bput(b,"    URL.revokeObjectURL(url);\n")
  val () = $B.bput(b,"  }\n")
in end

