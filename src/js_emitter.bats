  val () = refold(b)
  val () = emit_js_dom_read(b)
  val () = refold(b)
  val () = emit_js_event(b)
  val () = refold(b)
  val () = emit_js_fetch(b)
  val () = refold(b)
  val () = emit_js_clipboard(b)
  val () = refold(b)
  val () = emit_js_file(b)
  val () = refold(b)
  val () = emit_js_decompress(b)
  val () = refold(b)
  val () = emit_js_notify(b)
  val () = refold(b)
  val () = emit_js_xml(b)
