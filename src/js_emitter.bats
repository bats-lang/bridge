fn emit_js_dom_read {n:nat | n + 5500 <= $B.BUILDER_CAP}
  (b: !$B.builder(n) >> [m:nat | n <= m; m <= n + 5500] $B.builder(m)): void = let
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  // --- DOM read ---\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsMeasureNode(idPtr, idLen) {\n")
  val () = $B.bput(b,"    const id = readIdFromPtr(idPtr, idLen);\n")
  val () = $B.bput(b,"    const el = getEl(id);\n")
  val () = $B.bput(b,"    if (el && typeof el.getBoundingClientRect === 'function') {\n")
  val () = $B.bput(b,"      const rect = el.getBoundingClientRect();\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(0, Math.round(rect.x));\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(1, Math.round(rect.y));\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(2, Math.round(rect.width));\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(3, Math.round(rect.height));\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(4, el.scrollWidth || 0);\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(5, el.scrollHeight || 0);\n")
  val () = $B.bput(b,"      return 1;\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"    for (let i = 0; i < 6; i++) {\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(i, 0);\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"    return 0;\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsQuerySelector(selectorPtr, selectorLen) {\n")
  val () = $B.bput(b,"    const selector = readString(selectorPtr, selectorLen);\n")
  val () = $B.bput(b,"    try {\n")
  val () = $B.bput(b,"      const el = document.querySelector(selector);\n")
  val () = $B.bput(b,"      if (!el || !el.id) return 0;\n")
  val () = $B.bput(b,"      const bytes = new TextEncoder().encode(el.id);\n")
  val () = $B.bput(b,"      const stashId = stashData(bytes);\n")
  val () = $B.bput(b,"      instance.exports.bats_bridge_stash_set_int(1, stashId);\n")
  val () = $B.bput(b,"      return bytes.length;\n")
  val () = $B.bput(b,"    } catch(e) { return 0; }\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  (* New: caret_position_from_point *)
  val () = $B.bput(b,"  function batsJsCaretPositionFromPoint(x, y) {\n")
  val () = $B.bput(b,"    try {\n")
  val () = $B.bput(b,"      if (document.caretPositionFromPoint) {\n")
  val () = $B.bput(b,"        const pos = document.caretPositionFromPoint(x, y);\n")
  val () = $B.bput(b,"        return pos ? pos.offset : -1;\n")
  val () = $B.bput(b,"      }\n")
  val () = $B.bput(b,"      if (document.caretRangeFromPoint) {\n")
  val () = $B.bput(b,"        const range = document.caretRangeFromPoint(x, y);\n")
  val () = $B.bput(b,"        return range ? range.startOffset : -1;\n")
  val () = $B.bput(b,"      }\n")
  val () = $B.bput(b,"      return -1;\n")
  val () = $B.bput(b,"    } catch(e) { return -1; }\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  (* New: read_text_content *)
  val () = $B.bput(b,"  function batsJsReadTextContent(idPtr, idLen) {\n")
  val () = $B.bput(b,"    const id = readIdFromPtr(idPtr, idLen);\n")
  val () = $B.bput(b,"    const el = getEl(id);\n")
  val () = $B.bput(b,"    if (!el) return 0;\n")
  val () = $B.bput(b,"    const text = el.textContent || '';\n")
  val () = $B.bput(b,"    const bytes = new TextEncoder().encode(text);\n")
  val () = $B.bput(b,"    if (bytes.length === 0) return 0;\n")
  val () = $B.bput(b,"    const stashId = stashData(bytes);\n")
  val () = $B.bput(b,"    instance.exports.bats_bridge_stash_set_int(1, stashId);\n")
  val () = $B.bput(b,"    return bytes.length;\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  (* read_input_value: read form input .value *)
  val () = $B.bput(b,"  function batsJsReadInputValue(idPtr, idLen, destPtr, maxLen) {\n")
  val () = $B.bput(b,"    const id = readIdFromPtr(idPtr, idLen);\n")
  val () = $B.bput(b,"    const el = getEl(id);\n")
  val () = $B.bput(b,"    if (!el || el.value === undefined) return 0;\n")
  val () = $B.bput(b,"    const bytes = new TextEncoder().encode(el.value);\n")
  val () = $B.bput(b,"    if (bytes.length === 0) return 0;\n")
  val () = $B.bput(b,"    const stashId = stashData(bytes);\n")
  val () = $B.bput(b,"    instance.exports.bats_bridge_stash_set_int(1, stashId);\n")
  val () = $B.bput(b,"    return bytes.length;\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")

  (* click_node: programmatic .click() *)
  val () = $B.bput(b,"  function batsJsClickNode(idPtr, idLen) {\n")
  val () = $B.bput(b,"    const id = readIdFromPtr(idPtr, idLen);\n")
  val () = $B.bput(b,"    const el = getEl(id);\n")
  val () = $B.bput(b,"    if (el) el.click();\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")

  (* idb_delete_database *)
  val () = $B.bput(b,"  function batsJsIdbDeleteDatabase() {\n")
  val () = $B.bput(b,"    try { indexedDB.deleteDatabase('bats'); } catch(e) {}\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")

  (* reload *)
  val () = $B.bput(b,"  function batsJsReload() {\n")
  val () = $B.bput(b,"    try { root.ownerDocument.defaultView.location.reload(); } catch(e) {}\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")

  (* New: measure_text_offset *)
  val () = $B.bput(b,"  function batsJsMeasureTextOffset(idPtr, idLen, offset) {\n")
  val () = $B.bput(b,"    const id = readIdFromPtr(idPtr, idLen);\n")
  val () = $B.bput(b,"    const el = getEl(id);\n")
  val () = $B.bput(b,"    if (!el || !el.firstChild) return -1;\n")
  val () = $B.bput(b,"    try {\n")
  val () = $B.bput(b,"      const range = document.createRange();\n")
  val () = $B.bput(b,"      const textNode = el.firstChild;\n")
  val () = $B.bput(b,"      const clampOff = Math.min(offset, (textNode.textContent || '').length);\n")
  val () = $B.bput(b,"      range.setStart(textNode, clampOff);\n")
  val () = $B.bput(b,"      range.collapse(true);\n")
  val () = $B.bput(b,"      const rect = range.getBoundingClientRect();\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(0, Math.round(rect.x));\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(1, Math.round(rect.y));\n")
  val () = $B.bput(b,"      return 1;\n")
  val () = $B.bput(b,"    } catch(e) { return -1; }\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  (* New: get_selection_text *)
  val () = $B.bput(b,"  function batsJsGetSelectionText() {\n")
  val () = $B.bput(b,"    try {\n")
  val () = $B.bput(b,"      const sel = root.ownerDocument.defaultView.getSelection();\n")
  val () = $B.bput(b,"      if (!sel || sel.isCollapsed) return 0;\n")
  val () = $B.bput(b,"      const text = sel.toString();\n")
  val () = $B.bput(b,"      const bytes = new TextEncoder().encode(text);\n")
  val () = $B.bput(b,"      if (bytes.length === 0) return 0;\n")
  val () = $B.bput(b,"      const stashId = stashData(bytes);\n")
  val () = $B.bput(b,"      instance.exports.bats_bridge_stash_set_int(1, stashId);\n")
  val () = $B.bput(b,"      return bytes.length;\n")
  val () = $B.bput(b,"    } catch(e) { return 0; }\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  (* New: get_selection_rect *)
  val () = $B.bput(b,"  function batsJsGetSelectionRect() {\n")
  val () = $B.bput(b,"    try {\n")
  val () = $B.bput(b,"      const sel = root.ownerDocument.defaultView.getSelection();\n")
  val () = $B.bput(b,"      if (!sel || sel.rangeCount === 0) return;\n")
  val () = $B.bput(b,"      const rect = sel.getRangeAt(0).getBoundingClientRect();\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(0, Math.round(rect.x));\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(1, Math.round(rect.y));\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(2, Math.round(rect.width));\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(3, Math.round(rect.height));\n")
  val () = $B.bput(b,"    } catch(e) {}\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  (* New: get_selection_range *)
  val () = $B.bput(b,"  function batsJsGetSelectionRange() {\n")
  val () = $B.bput(b,"    try {\n")
  val () = $B.bput(b,"      const sel = root.ownerDocument.defaultView.getSelection();\n")
  val () = $B.bput(b,"      if (!sel || sel.rangeCount === 0) return;\n")
  val () = $B.bput(b,"      const range = sel.getRangeAt(0);\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(0, range.startOffset);\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(1, range.endOffset);\n")
  val () = $B.bput(b,"      const sc = range.startContainer.parentNode || range.startContainer;\n")
  val () = $B.bput(b,"      const ec = range.endContainer.parentNode || range.endContainer;\n")
  val () = $B.bput(b,"      const sid = (sc.id || '');\n")
  val () = $B.bput(b,"      const eid = (ec.id || '');\n")
  val () = $B.bput(b,"      const sb = new TextEncoder().encode(sid);\n")
  val () = $B.bput(b,"      const eb = new TextEncoder().encode(eid);\n")
  val () = $B.bput(b,"      instance.exports.bats_bridge_stash_set_int(2, stashData(sb));\n")
  val () = $B.bput(b,"      instance.exports.bats_bridge_stash_set_int(3, stashData(eb));\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(2, sb.length);\n")
  val () = $B.bput(b,"      instance.exports.bats_measure_set(3, eb.length);\n")
  val () = $B.bput(b,"    } catch(e) {}\n")
  val () = $B.bput(b,"  }\n")
in end

fn emit_js_event {n:nat | n + 4500 <= $B.BUILDER_CAP}
  (b: !$B.builder(n) >> [m:nat | n <= m; m <= n + 4500] $B.builder(m)): void = let
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  // --- Event listener ---\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  const listenerMap = new Map();\n")
  val () = $B.bput(b,"  let currentEvent = null;\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function encodeEventPayload(event, eventType) {\n")
  val () = $B.bput(b,"    if (eventType === 'click' || eventType === 'pointerdown' ||\n")
  val () = $B.bput(b,"        eventType === 'pointerup' || eventType === 'pointermove') {\n")
  val () = $B.bput(b,"      const targetId = (event.target && event.target.id) || '';\n")
  val () = $B.bput(b,"      const idBytes = new TextEncoder().encode(targetId);\n")
  val () = $B.bput(b,"      const buf = new ArrayBuffer(16 + 2 + idBytes.length);\n")
  val () = $B.bput(b,"      const dv = new DataView(buf);\n")
  val () = $B.bput(b,"      dv.setFloat64(0, event.clientX || 0, true);\n")
  val () = $B.bput(b,"      dv.setFloat64(8, event.clientY || 0, true);\n")
  val () = $B.bput(b,"      dv.setUint16(16, idBytes.length, true);\n")
  val () = $B.bput(b,"      new Uint8Array(buf).set(idBytes, 18);\n")
  val () = $B.bput(b,"      return new Uint8Array(buf);\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"    if (eventType === 'keydown' || eventType === 'keyup') {\n")
  val () = $B.bput(b,"      const key = event.key || '';\n")
  val () = $B.bput(b,"      const keyBytes = new TextEncoder().encode(key);\n")
  val () = $B.bput(b,"      const buf = new Uint8Array(1 + keyBytes.length + 1);\n")
  val () = $B.bput(b,"      buf[0] = keyBytes.length;\n")
  val () = $B.bput(b,"      buf.set(keyBytes, 1);\n")
  val () = $B.bput(b,"      const flags = (event.shiftKey ? 1 : 0) | (event.ctrlKey ? 2 : 0) |\n")
  val () = $B.bput(b,"                    (event.altKey ? 4 : 0) | (event.metaKey ? 8 : 0);\n")
  val () = $B.bput(b,"      buf[1 + keyBytes.length] = flags;\n")
  val () = $B.bput(b,"      return buf;\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"    if (eventType === 'input') {\n")
  val () = $B.bput(b,"      const value = (event.target && event.target.value) || '';\n")
  val () = $B.bput(b,"      const valBytes = new TextEncoder().encode(value);\n")
  val () = $B.bput(b,"      const buf = new Uint8Array(2 + valBytes.length);\n")
  val () = $B.bput(b,"      buf[0] = valBytes.length & 0xFF;\n")
  val () = $B.bput(b,"      buf[1] = (valBytes.length >> 8) & 0xFF;\n")
  val () = $B.bput(b,"      buf.set(valBytes, 2);\n")
  val () = $B.bput(b,"      return buf;\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"    if (eventType === 'scroll') {\n")
  val () = $B.bput(b,"      const buf = new ArrayBuffer(16);\n")
  val () = $B.bput(b,"      const dv = new DataView(buf);\n")
  val () = $B.bput(b,"      const target = event.target || {};\n")
  val () = $B.bput(b,"      dv.setFloat64(0, target.scrollTop || 0, true);\n")
  val () = $B.bput(b,"      dv.setFloat64(8, target.scrollLeft || 0, true);\n")
  val () = $B.bput(b,"      return new Uint8Array(buf);\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"    if (eventType === 'resize') {\n")
  val () = $B.bput(b,"      const buf = new ArrayBuffer(16);\n")
  val () = $B.bput(b,"      const dv = new DataView(buf);\n")
  val () = $B.bput(b,"      const win = root.ownerDocument.defaultView || {};\n")
  val () = $B.bput(b,"      dv.setFloat64(0, win.innerWidth || 0, true);\n")
  val () = $B.bput(b,"      dv.setFloat64(8, win.innerHeight || 0, true);\n")
  val () = $B.bput(b,"      return new Uint8Array(buf);\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"    if (eventType === 'touchstart' || eventType === 'touchend' || eventType === 'touchmove') {\n")
  val () = $B.bput(b,"      const touch = (event.touches && event.touches[0]) ||\n")
  val () = $B.bput(b,"                    (event.changedTouches && event.changedTouches[0]);\n")
  val () = $B.bput(b,"      if (touch) {\n")
  val () = $B.bput(b,"        const buf = new ArrayBuffer(20);\n")
  val () = $B.bput(b,"        const dv = new DataView(buf);\n")
  val () = $B.bput(b,"        dv.setFloat64(0, touch.clientX || 0, true);\n")
  val () = $B.bput(b,"        dv.setFloat64(8, touch.clientY || 0, true);\n")
  val () = $B.bput(b,"        dv.setInt32(16, touch.identifier || 0, true);\n")
  val () = $B.bput(b,"        return new Uint8Array(buf);\n")
  val () = $B.bput(b,"      }\n")
  val () = $B.bput(b,"      return null;\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"    if (eventType === 'visibilitychange') {\n")
  val () = $B.bput(b,"      return new Uint8Array([document.visibilityState === 'hidden' ? 1 : 0]);\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"    return null;\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsFireEvent(listenerId, event, eventType) {\n")
  val () = $B.bput(b,"    currentEvent = event;\n")
  val () = $B.bput(b,"    const payload = encodeEventPayload(event, eventType);\n")
  val () = $B.bput(b,"    if (payload) {\n")
  val () = $B.bput(b,"      const stashId = stashData(payload);\n")
  val () = $B.bput(b,"      instance.exports.bats_bridge_stash_set_int(1, stashId);\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"    instance.exports.bats_on_event(listenerId, payload ? payload.length : 0);\n")
  val () = $B.bput(b,"    currentEvent = null;\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsAddEventListener(idPtr, idLen, eventTypePtr, typeLen, listenerId) {\n")
  val () = $B.bput(b,"    const id = readIdFromPtr(idPtr, idLen);\n")
  val () = $B.bput(b,"    const node = getEl(id);\n")
  val () = $B.bput(b,"    if (!node) return;\n")
  val () = $B.bput(b,"    const eventType = readString(eventTypePtr, typeLen);\n")
  val () = $B.bput(b,"    const handler = (event) => batsJsFireEvent(listenerId, event, eventType);\n")
  val () = $B.bput(b,"    listenerMap.set(listenerId, { node, eventType, handler });\n")
  val () = $B.bput(b,"    node.addEventListener(eventType, handler);\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  (* New: listen on document *)
  val () = $B.bput(b,"  function batsJsAddDocumentListener(eventTypePtr, typeLen, listenerId) {\n")
  val () = $B.bput(b,"    const eventType = readString(eventTypePtr, typeLen);\n")
  val () = $B.bput(b,"    const handler = (event) => batsJsFireEvent(listenerId, event, eventType);\n")
  val () = $B.bput(b,"    listenerMap.set(listenerId, { node: document, eventType, handler });\n")
  val () = $B.bput(b,"    document.addEventListener(eventType, handler);\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsRemoveEventListener(listenerId) {\n")
  val () = $B.bput(b,"    const entry = listenerMap.get(listenerId);\n")
  val () = $B.bput(b,"    if (entry) {\n")
  val () = $B.bput(b,"      entry.node.removeEventListener(entry.eventType, entry.handler);\n")
  val () = $B.bput(b,"      listenerMap.delete(listenerId);\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsPreventDefault() {\n")
  val () = $B.bput(b,"    if (currentEvent) currentEvent.preventDefault();\n")
  val () = $B.bput(b,"  }\n")
in end

fn emit_js_fetch {n:nat | n + 600 <= $B.BUILDER_CAP}
  (b: !$B.builder(n) >> [m:nat | n <= m; m <= n + 600] $B.builder(m)): void = let
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  // --- Fetch ---\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsFetch(urlPtr, urlLen, resolverId) {\n")
  val () = $B.bput(b,"    const url = readString(urlPtr, urlLen);\n")
  val () = $B.bput(b,"    fetch(url).then(async (response) => {\n")
  val () = $B.bput(b,"      const body = new Uint8Array(await response.arrayBuffer());\n")
  val () = $B.bput(b,"      if (body.length > 0) {\n")
  val () = $B.bput(b,"        const stashId = stashData(body);\n")
  val () = $B.bput(b,"        instance.exports.bats_bridge_stash_set_int(1, stashId);\n")
  val () = $B.bput(b,"      }\n")
  val () = $B.bput(b,"      instance.exports.bats_on_fetch_complete(resolverId, response.status, body.length);\n")
  val () = $B.bput(b,"    }).catch(() => {\n")
  val () = $B.bput(b,"      instance.exports.bats_on_fetch_complete(resolverId, 0, 0);\n")
  val () = $B.bput(b,"    });\n")
  val () = $B.bput(b,"  }\n")
in end

fn emit_js_clipboard {n:nat | n + 1600 <= $B.BUILDER_CAP}
  (b: !$B.builder(n) >> [m:nat | n <= m; m <= n + 1600] $B.builder(m)): void = let
