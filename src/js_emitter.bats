  val () = $B.bput(b,"      // Clipboard\n")
  val () = $B.bput(b,"      bats_js_clipboard_write_text: batsJsClipboardWriteText,\n")
  val () = $B.bput(b,"      bats_js_clipboard_read_text: batsJsClipboardReadText,\n")
  val () = $B.bput(b,"      // File\n")
  val () = $B.bput(b,"      bats_js_file_open: batsJsFileOpen,\n")
  val () = $B.bput(b,"      bats_js_file_read: batsJsFileRead,\n")
  val () = $B.bput(b,"      bats_js_file_close: batsJsFileClose,\n")
  val () = $B.bput(b,"      // Decompress\n")
  val () = $B.bput(b,"      bats_js_decompress: batsJsDecompress,\n")
  val () = $B.bput(b,"      bats_js_blob_read: batsJsBlobRead,\n")
  val () = $B.bput(b,"      bats_js_blob_free: batsJsBlobFree,\n")
  val () = $B.bput(b,"      // Notification/Push\n")
  val () = $B.bput(b,"      bats_js_notification_request_permission: batsJsNotificationRequestPermission,\n")
  val () = $B.bput(b,"      bats_js_notification_show: batsJsNotificationShow,\n")
  val () = $B.bput(b,"      bats_js_push_subscribe: batsJsPushSubscribe,\n")
