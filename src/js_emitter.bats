  val () = $B.bput(b,"  // --- Notification/Push ---\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsNotificationRequestPermission(resolverId) {\n")
  val () = $B.bput(b,"    if (typeof Notification === 'undefined') {\n")
