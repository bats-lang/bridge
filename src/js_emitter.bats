  val () = $B.bput(b,"            if (bytes.length > 0) {\n")
  val () = $B.bput(b,"              const stashId = stashData(bytes);\n")
  val () = $B.bput(b,"              instance.exports.bats_bridge_stash_set_int(1, stashId);\n")
