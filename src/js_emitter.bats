  val () = $B.bput(b,"          applicationServerKey: vapidBytes,\n")
  val () = $B.bput(b,"        });\n")
  val () = $B.bput(b,"      }).then((sub) => {\n")
  val () = $B.bput(b,"        const json = JSON.stringify(sub.toJSON());\n")
