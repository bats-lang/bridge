  val () = $B.bput(b,"    if (!data) return 0;\n")
  val () = $B.bput(b,"    const available = Math.max(0, data.length - blobOffset);\n")
  val () = $B.bput(b,"    const copyLen = Math.min(len, available);\n")
  val () = $B.bput(b,"    if (copyLen > 0) {\n")
  val () = $B.bput(b,"      new Uint8Array(instance.exports.memory.buffer).set(\n")
  val () = $B.bput(b,"        data.subarray(blobOffset, blobOffset + copyLen), outPtr);\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"    return copyLen;\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsBlobFree(handle) {\n")
  val () = $B.bput(b,"    blobCache.delete(handle);\n")
