(* js_emitter -- ALL JS-generating functions for the bridge *)
(* Kept in a single file so native code can call produce_bridge *)

#include "share/atspre_staload.hats"

#use builder as B

(* ============================================================
   String builder helpers (visible to lib.bats via module)
   ============================================================ *)

#pub fun emit_js_all {n:nat | n + 45400 <= $B.BUILDER_CAP}
  (b: !$B.builder(n) >> [m:nat | n <= m; m <= n + 45400] $B.builder(m)): void

(* ============================================================
   Per-concept JS emitters
   ============================================================ *)

fn emit_js_header {n:nat | n + 500 <= $B.BUILDER_CAP}
  (b: !$B.builder(n) >> [m:nat | n <= m; m <= n + 500] $B.builder(m)): void = let
  val () = $B.bput(b,"// bats_bridge.mjs — Bridge between bats WASM and a DOM document\n")
  val () = $B.bput(b,"// Parses the bats binary diff protocol and applies it to a standard DOM.\n")
  val () = $B.bput(b,"// Works in any ES module environment (browser or Node.js).\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"// Parse a little-endian i32 from a Uint8Array at offset\n")
  val () = $B.bput(b,"function readI32(buf, off) {\n")
  val () = $B.bput(b,"  return buf[off] | (buf[off+1] << 8) | (buf[off+2] << 16) | (buf[off+3] << 24);\n")
  val () = $B.bput(b,"}\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"function readU16LE(buf, off) {\n")
  val () = $B.bput(b,"  return buf[off] | (buf[off+1] << 8);\n")
  val () = $B.bput(b,"}\n")
in end

fn emit_js_loadwasm_open {n:nat | n + 2000 <= $B.BUILDER_CAP}
  (b: !$B.builder(n) >> [m:nat | n <= m; m <= n + 2000] $B.builder(m)): void = let
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"/**\n")
  val () = $B.bput(b," * Load a bats WASM module and connect it to a DOM document.\n")
  val () = $B.bput(b," *\n")
  val () = $B.bput(b," * @param {BufferSource} wasmBytes — compiled WASM bytes\n")
  val () = $B.bput(b," * @param {Element} root — root element for bats to render into\n")
  val () = $B.bput(b," * @returns {{ exports, done }} — WASM exports,\n")
  val () = $B.bput(b," *   and a promise that resolves when WASM calls exit\n")
  val () = $B.bput(b," */\n")
  val () = $B.bput(b,"export async function loadWASM(wasmBytes, root, opts) {\n")
  val () = $B.bput(b,"  const extraImports = (opts && opts.extraImports) || {};\n")
  val () = $B.bput(b,"  const document = root.ownerDocument;\n")
  val () = $B.bput(b,"  let instance = null;\n")
  val () = $B.bput(b,"  let resolveDone;\n")
  val () = $B.bput(b,"  const done = new Promise(r => { resolveDone = r; });\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  // Ensure root has an id for getElementById lookup\n")
  val () = $B.bput(b,"  if (!root.id) root.id = 'bats-root';\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function readBytes(ptr, len) {\n")
  val () = $B.bput(b,"    return new Uint8Array(instance.exports.memory.buffer, ptr, len).slice();\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function readString(ptr, len) {\n")
  val () = $B.bput(b,"    return new TextDecoder().decode(readBytes(ptr, len));\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  // JS-side data stash — WASM pulls data via bats_js_stash_read\n")
  val () = $B.bput(b,"  const dataStash = new Map();\n")
  val () = $B.bput(b,"  let nextStashId = 0;\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function stashData(data) {\n")
  val () = $B.bput(b,"    const id = nextStashId++;\n")
  val () = $B.bput(b,"    dataStash.set(id, data);\n")
  val () = $B.bput(b,"    return id;\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsStashRead(stashId, destPtr, len) {\n")
  val () = $B.bput(b,"    const data = dataStash.get(stashId);\n")
  val () = $B.bput(b,"    if (data) {\n")
  val () = $B.bput(b,"      const copyLen = Math.min(len, data.length);\n")
  val () = $B.bput(b,"      new Uint8Array(instance.exports.memory.buffer).set(\n")
  val () = $B.bput(b,"        data.subarray(0, copyLen), destPtr);\n")
  val () = $B.bput(b,"      dataStash.delete(stashId);\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  // Blob URL lifecycle tracking — revoked when element gets new image or is removed\n")
  val () = $B.bput(b,"  const blobUrls = new Map();\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function writeStringToWasm(str, outPtr, maxLen) {\n")
  val () = $B.bput(b,"    const encoded = new TextEncoder().encode(str);\n")
  val () = $B.bput(b,"    const len = Math.min(encoded.length, maxLen);\n")
  val () = $B.bput(b,"    new Uint8Array(instance.exports.memory.buffer).set(encoded.subarray(0, len), outPtr);\n")
  val () = $B.bput(b,"    return len;\n")
  val () = $B.bput(b,"  }\n")
in end

fn emit_js_dom {n:nat | n + 9000 <= $B.BUILDER_CAP}
  (b: !$B.builder(n) >> [m:nat | n <= m; m <= n + 9000] $B.builder(m)): void = let
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  // --- DOM helpers ---\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function readIdFromPtr(ptr, len) {\n")
  val () = $B.bput(b,"    const mem = new Uint8Array(instance.exports.memory.buffer);\n")
  val () = $B.bput(b,"    return _dec.decode(mem.slice(ptr, ptr + len));\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"\n")
  (* Canvas context cache *)
  val () = $B.bput(b,"  const ctxCache = new Map();\n")
  val () = $B.bput(b,"  function getCtx(id) {\n")
  val () = $B.bput(b,"    let ctx = ctxCache.get(id);\n")
  val () = $B.bput(b,"    if (ctx) return ctx;\n")
  val () = $B.bput(b,"    const el = document.getElementById(id);\n")
  val () = $B.bput(b,"    if (el && el.getContext) { ctx = el.getContext('2d'); ctxCache.set(id, ctx); return ctx; }\n")
  val () = $B.bput(b,"    return null;\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  // --- DOM flush ---\n")
  val () = $B.bput(b,"  const _dec = new TextDecoder();\n")
  val () = $B.bput(b,"  function readStr(mem, base, off) {\n")
  val () = $B.bput(b,"    const len = mem[base + off] | (mem[base + off + 1] << 8);\n")
  val () = $B.bput(b,"    return { s: _dec.decode(mem.slice(base + off + 2, base + off + 2 + len)), len: len };\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"  function getEl(id) { return document.getElementById(id); }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsDomFlush(bufPtr, len) {\n")
  val () = $B.bput(b,"    const mem = new Uint8Array(instance.exports.memory.buffer);\n")
  val () = $B.bput(b,"    let pos = 0;\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"    while (pos < len) {\n")
  val () = $B.bput(b,"      const op = mem[bufPtr + pos];\n")
  val () = $B.bput(b,"      const nid = readStr(mem, bufPtr, pos + 1);\n")
  val () = $B.bput(b,"      const dataStart = pos + 1 + 2 + nid.len;\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"      switch (op) {\n")
  val () = $B.bput(b,"        case 4: { // CREATE_ELEMENT\n")
  val () = $B.bput(b,"          const pid = readStr(mem, bufPtr, dataStart);\n")
  val () = $B.bput(b,"          const d2 = dataStart + 2 + pid.len;\n")
  val () = $B.bput(b,"          const tagLen = mem[bufPtr + d2];\n")
  val () = $B.bput(b,"          const tag = _dec.decode(mem.slice(bufPtr + d2 + 1, bufPtr + d2 + 1 + tagLen));\n")
  val () = $B.bput(b,"          const el = document.createElement(tag);\n")
  val () = $B.bput(b,"          el.id = nid.s;\n")
  val () = $B.bput(b,"          const parent = getEl(pid.s);\n")
  val () = $B.bput(b,"          if (parent) parent.appendChild(el);\n")
  val () = $B.bput(b,"          pos = d2 + 1 + tagLen;\n")
  val () = $B.bput(b,"          break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 1: { // SET_TEXT\n")
  val () = $B.bput(b,"          const textLen = mem[bufPtr + dataStart] | (mem[bufPtr + dataStart + 1] << 8);\n")
  val () = $B.bput(b,"          const text = _dec.decode(mem.slice(bufPtr + dataStart + 2, bufPtr + dataStart + 2 + textLen));\n")
  val () = $B.bput(b,"          const el = getEl(nid.s);\n")
  val () = $B.bput(b,"          if (el) el.textContent = text;\n")
  val () = $B.bput(b,"          pos = dataStart + 2 + textLen;\n")
  val () = $B.bput(b,"          break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 2: { // SET_ATTR\n")
  val () = $B.bput(b,"          const nameLen = mem[bufPtr + dataStart];\n")
  val () = $B.bput(b,"          const name = _dec.decode(mem.slice(bufPtr + dataStart + 1, bufPtr + dataStart + 1 + nameLen));\n")
  val () = $B.bput(b,"          const valOff = dataStart + 1 + nameLen;\n")
  val () = $B.bput(b,"          const valLen = mem[bufPtr + valOff] | (mem[bufPtr + valOff + 1] << 8);\n")
  val () = $B.bput(b,"          const value = _dec.decode(mem.slice(bufPtr + valOff + 2, bufPtr + valOff + 2 + valLen));\n")
  val () = $B.bput(b,"          const el = getEl(nid.s);\n")
  val () = $B.bput(b,"          if (el) el.setAttribute(name, value);\n")
  val () = $B.bput(b,"          pos = valOff + 2 + valLen;\n")
  val () = $B.bput(b,"          break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 3: { // REMOVE_CHILDREN\n")
  val () = $B.bput(b,"          const el = getEl(nid.s);\n")
  val () = $B.bput(b,"          if (el) el.innerHTML = '';\n")
  val () = $B.bput(b,"          pos = dataStart;\n")
  val () = $B.bput(b,"          break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 5: { // REMOVE_CHILD\n")
  val () = $B.bput(b,"          const el = getEl(nid.s);\n")
  val () = $B.bput(b,"          if (el) el.remove();\n")
  val () = $B.bput(b,"          pos = dataStart;\n")
  val () = $B.bput(b,"          break;\n")
  val () = $B.bput(b,"        }\n")
  (* Canvas opcodes 64-84 — all use dataStart for params, nid.s for element *)
  val () = $B.bput(b,"        case 64: { // CANVAS_FILL_RECT\n")
  val () = $B.bput(b,"          const x=readI32(mem,bufPtr+dataStart),y=readI32(mem,bufPtr+dataStart+4),w=readI32(mem,bufPtr+dataStart+8),h=readI32(mem,bufPtr+dataStart+12);\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.fillRect(x,y,w,h);\n")
  val () = $B.bput(b,"          pos=dataStart+16; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 65: { // CANVAS_STROKE_RECT\n")
  val () = $B.bput(b,"          const x=readI32(mem,bufPtr+dataStart),y=readI32(mem,bufPtr+dataStart+4),w=readI32(mem,bufPtr+dataStart+8),h=readI32(mem,bufPtr+dataStart+12);\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.strokeRect(x,y,w,h);\n")
  val () = $B.bput(b,"          pos=dataStart+16; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 66: { // CANVAS_CLEAR_RECT\n")
  val () = $B.bput(b,"          const x=readI32(mem,bufPtr+dataStart),y=readI32(mem,bufPtr+dataStart+4),w=readI32(mem,bufPtr+dataStart+8),h=readI32(mem,bufPtr+dataStart+12);\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.clearRect(x,y,w,h);\n")
  val () = $B.bput(b,"          pos=dataStart+16; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 67: { // CANVAS_BEGIN_PATH\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.beginPath();\n")
  val () = $B.bput(b,"          pos=dataStart; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 68: { // CANVAS_MOVE_TO\n")
  val () = $B.bput(b,"          const x=readI32(mem,bufPtr+dataStart),y=readI32(mem,bufPtr+dataStart+4);\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.moveTo(x,y);\n")
  val () = $B.bput(b,"          pos=dataStart+8; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 69: { // CANVAS_LINE_TO\n")
  val () = $B.bput(b,"          const x=readI32(mem,bufPtr+dataStart),y=readI32(mem,bufPtr+dataStart+4);\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.lineTo(x,y);\n")
  val () = $B.bput(b,"          pos=dataStart+8; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 70: { // CANVAS_ARC\n")
  val () = $B.bput(b,"          const cx=readI32(mem,bufPtr+dataStart),cy=readI32(mem,bufPtr+dataStart+4),r=readI32(mem,bufPtr+dataStart+8);\n")
  val () = $B.bput(b,"          const s1000=readI32(mem,bufPtr+dataStart+12),e1000=readI32(mem,bufPtr+dataStart+16);\n")
  val () = $B.bput(b,"          const ccw=mem[bufPtr+dataStart+20];\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.arc(cx,cy,r,s1000/1000,e1000/1000,ccw!==0);\n")
  val () = $B.bput(b,"          pos=dataStart+21; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 71: { // CANVAS_CLOSE_PATH\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.closePath();\n")
  val () = $B.bput(b,"          pos=dataStart; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 72: { // CANVAS_FILL\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.fill();\n")
  val () = $B.bput(b,"          pos=dataStart; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 73: { // CANVAS_STROKE\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.stroke();\n")
  val () = $B.bput(b,"          pos=dataStart; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 74: { // CANVAS_FILL_COLOR\n")
  val () = $B.bput(b,"          const r0=mem[bufPtr+dataStart],g0=mem[bufPtr+dataStart+1],b0=mem[bufPtr+dataStart+2],a0=mem[bufPtr+dataStart+3];\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.fillStyle=`rgba(${r0},${g0},${b0},${a0/255})`;\n")
  val () = $B.bput(b,"          pos=dataStart+4; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 75: { // CANVAS_STROKE_COLOR\n")
  val () = $B.bput(b,"          const r0=mem[bufPtr+dataStart],g0=mem[bufPtr+dataStart+1],b0=mem[bufPtr+dataStart+2],a0=mem[bufPtr+dataStart+3];\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.strokeStyle=`rgba(${r0},${g0},${b0},${a0/255})`;\n")
  val () = $B.bput(b,"          pos=dataStart+4; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 76: { // CANVAS_LINE_WIDTH\n")
  val () = $B.bput(b,"          const w100=readI32(mem,bufPtr+dataStart);\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.lineWidth=w100/100;\n")
  val () = $B.bput(b,"          pos=dataStart+4; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 77: { // CANVAS_FILL_TEXT\n")
  val () = $B.bput(b,"          const x=readI32(mem,bufPtr+dataStart),y=readI32(mem,bufPtr+dataStart+4);\n")
  val () = $B.bput(b,"          const tl=readU16LE(mem,bufPtr+dataStart+8);\n")
  val () = $B.bput(b,"          const t=_dec.decode(mem.slice(bufPtr+dataStart+10,bufPtr+dataStart+10+tl));\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.fillText(t,x,y);\n")
  val () = $B.bput(b,"          pos=dataStart+10+tl; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 78: { // CANVAS_STROKE_TEXT\n")
  val () = $B.bput(b,"          const x=readI32(mem,bufPtr+dataStart),y=readI32(mem,bufPtr+dataStart+4);\n")
  val () = $B.bput(b,"          const tl=readU16LE(mem,bufPtr+dataStart+8);\n")
  val () = $B.bput(b,"          const t=_dec.decode(mem.slice(bufPtr+dataStart+10,bufPtr+dataStart+10+tl));\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.strokeText(t,x,y);\n")
  val () = $B.bput(b,"          pos=dataStart+10+tl; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 79: { // CANVAS_SET_FONT\n")
  val () = $B.bput(b,"          const fl=readU16LE(mem,bufPtr+dataStart);\n")
  val () = $B.bput(b,"          const f=_dec.decode(mem.slice(bufPtr+dataStart+2,bufPtr+dataStart+2+fl));\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.font=f;\n")
  val () = $B.bput(b,"          pos=dataStart+2+fl; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 80: { // CANVAS_SAVE\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.save();\n")
  val () = $B.bput(b,"          pos=dataStart; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 81: { // CANVAS_RESTORE\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.restore();\n")
  val () = $B.bput(b,"          pos=dataStart; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 82: { // CANVAS_TRANSLATE\n")
  val () = $B.bput(b,"          const x=readI32(mem,bufPtr+dataStart),y=readI32(mem,bufPtr+dataStart+4);\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.translate(x,y);\n")
  val () = $B.bput(b,"          pos=dataStart+8; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 83: { // CANVAS_ROTATE\n")
  val () = $B.bput(b,"          const a1000=readI32(mem,bufPtr+dataStart);\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.rotate(a1000/1000);\n")
  val () = $B.bput(b,"          pos=dataStart+4; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        case 84: { // CANVAS_SCALE\n")
  val () = $B.bput(b,"          const sx1000=readI32(mem,bufPtr+dataStart),sy1000=readI32(mem,bufPtr+dataStart+4);\n")
  val () = $B.bput(b,"          const ctx=getCtx(nid.s); if(ctx) ctx.scale(sx1000/1000,sy1000/1000);\n")
  val () = $B.bput(b,"          pos=dataStart+8; break;\n")
  val () = $B.bput(b,"        }\n")
  val () = $B.bput(b,"        default:\n")
  val () = $B.bput(b,"          throw new Error(`Unknown bats DOM op: ${op} at offset ${pos}`);\n")
  val () = $B.bput(b,"      }\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsSetImageSrc(idPtr, idLen, dataPtr, dataLen, mimePtr, mimeLen) {\n")
  val () = $B.bput(b,"    const id = readIdFromPtr(idPtr, idLen);\n")
  val () = $B.bput(b,"    const mime = readString(mimePtr, mimeLen);\n")
  val () = $B.bput(b,"    const bytes = readBytes(dataPtr, dataLen);\n")
  val () = $B.bput(b,"    const oldUrl = blobUrls.get(id);\n")
  val () = $B.bput(b,"    if (oldUrl) URL.revokeObjectURL(oldUrl);\n")
  val () = $B.bput(b,"    const blob = new Blob([bytes], { type: mime });\n")
  val () = $B.bput(b,"    const url = URL.createObjectURL(blob);\n")
  val () = $B.bput(b,"    const el = getEl(id);\n")
  val () = $B.bput(b,"    if (el) el.src = url;\n")
  val () = $B.bput(b,"    blobUrls.set(id, url);\n")
  val () = $B.bput(b,"  }\n")
in end

fn emit_js_timer {n:nat | n + 200 <= $B.BUILDER_CAP}
  (b: !$B.builder(n) >> [m:nat | n <= m; m <= n + 200] $B.builder(m)): void = let
