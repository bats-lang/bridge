  val () = $B.bput(b,"        win.navigator.clipboard.writeText(text).then(\n")
  val () = $B.bput(b,"          () => { instance.exports.bats_on_clipboard_complete(resolverId, 1); },\n")
  val () = $B.bput(b,"          () => { instance.exports.bats_on_clipboard_complete(resolverId, 0); }\n")
  val () = $B.bput(b,"        );\n")
  val () = $B.bput(b,"      } else {\n")
  val () = $B.bput(b,"        instance.exports.bats_on_clipboard_complete(resolverId, 0);\n")
  val () = $B.bput(b,"      }\n")
  val () = $B.bput(b,"    } catch(e) {\n")
  val () = $B.bput(b,"      instance.exports.bats_on_clipboard_complete(resolverId, 0);\n")
  val () = $B.bput(b,"    }\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  (* New: clipboard read *)
  val () = $B.bput(b,"  function batsJsClipboardReadText(resolverId) {\n")
  val () = $B.bput(b,"    try {\n")
  val () = $B.bput(b,"      const win = root.ownerDocument.defaultView;\n")
  val () = $B.bput(b,"      if (win && win.navigator && win.navigator.clipboard) {\n")
