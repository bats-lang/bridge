  val () = $B.bput(b,"    const title = readString(titlePtr, titleLen);\n")
  val () = $B.bput(b,"    try { new Notification(title); } catch(e) {}\n")
  val () = $B.bput(b,"  }\n")
  val () = $B.bput(b,"\n")
  val () = $B.bput(b,"  function batsJsPushSubscribe(vapidPtr, vapidLen, resolverId) {\n")
